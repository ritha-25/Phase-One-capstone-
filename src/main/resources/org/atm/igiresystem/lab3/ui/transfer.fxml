<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.atm.igiresystem.lab3.ui.controllers.TransferController"
      stylesheets="@styles.css"
      spacing="20">

    <HBox spacing="0" style="-fx-background-color:#FFFFFF;-fx-background-radius:10;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
        <Button fx:id="tabDeposit"  text="Deposit"    onAction="#switchToDeposit"
                style="-fx-background-color:#005B2A;-fx-text-fill:white;-fx-font-weight:bold;-fx-padding:12 24;-fx-background-radius:10 0 0 10;-fx-cursor:hand;"/>
        <Button fx:id="tabWithdraw" text="Withdraw"   onAction="#switchToWithdraw"
                style="-fx-background-color:#F5F5F5;-fx-text-fill:#4B4B4B;-fx-font-weight:bold;-fx-padding:12 24;-fx-background-radius:0;-fx-cursor:hand;"/>
        <Button fx:id="tabTransfer" text="Send Money" onAction="#switchToTransfer"
                style="-fx-background-color:#F5F5F5;-fx-text-fill:#4B4B4B;-fx-font-weight:bold;-fx-padding:12 24;-fx-background-radius:0 10 10 0;-fx-cursor:hand;"/>
    </HBox>

    <!-- DEPOSIT FORM — Wallet only -->
    <VBox fx:id="depositForm" styleClass="card" spacing="16" maxWidth="480">
        <Label text="Deposit Money" styleClass="lbl-screen-title"/>
        <Label text="Deposit cash into your Main Wallet." style="-fx-text-fill:#6B7280;-fx-font-size:12px;"/>
        <Separator/>
        <VBox spacing="6">
            <Label text="SELECT WALLET" styleClass="lbl-field"/>
            <ComboBox fx:id="depositAccountCombo" promptText="Choose wallet account" maxWidth="Infinity" style="-fx-font-size:13px;"/>
        </VBox>
        <VBox spacing="6">
            <Label text="AMOUNT (RWF)" styleClass="lbl-field"/>
            <TextField fx:id="depositAmount" promptText="e.g. 10,000" styleClass="input-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="PIN" styleClass="lbl-field"/>
            <PasswordField fx:id="depositPin" promptText="Enter your PIN" styleClass="input-field"/>
        </VBox>
        <Label fx:id="depositMsg" wrapText="true"/>
        <Button text="Deposit" styleClass="btn-green" onAction="#handleDeposit" maxWidth="Infinity"/>
    </VBox>

    <!-- WITHDRAW FORM — Wallet only, fee applies -->
    <VBox fx:id="withdrawForm" styleClass="card" spacing="16" maxWidth="480" visible="false" managed="false">
        <Label text="Withdraw Money" styleClass="lbl-screen-title"/>
        <Label text="Withdraw from your Main Wallet. Fee: 100 RWF. To withdraw savings, use the Savings screen." style="-fx-text-fill:#6B7280;-fx-font-size:12px;" wrapText="true"/>
        <Separator/>
        <VBox spacing="6">
            <Label text="SELECT WALLET" styleClass="lbl-field"/>
            <ComboBox fx:id="withdrawAccountCombo" promptText="Choose wallet account" maxWidth="Infinity" style="-fx-font-size:13px;"/>
        </VBox>
        <VBox spacing="6">
            <Label text="AMOUNT (RWF)" styleClass="lbl-field"/>
            <TextField fx:id="withdrawAmount" promptText="e.g. 5,000" styleClass="input-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="PIN" styleClass="lbl-field"/>
            <PasswordField fx:id="withdrawPin" promptText="Enter your PIN" styleClass="input-field"/>
        </VBox>
        <Label fx:id="withdrawMsg" wrapText="true"/>
        <Button text="Withdraw" styleClass="btn-orange" onAction="#handleWithdraw" maxWidth="Infinity"/>
    </VBox>

    <!-- SEND MONEY — External only, with reference ID display -->
    <VBox fx:id="transferForm" styleClass="card" spacing="16" maxWidth="480" visible="false" managed="false">
        <Label text="Send Money" styleClass="lbl-screen-title"/>
        <Label text="Send to another IgirePay user. Fee: 100 RWF. Only from Main Wallet." style="-fx-text-fill:#6B7280;-fx-font-size:12px;" wrapText="true"/>
        <Separator/>

        <VBox spacing="6">
            <Label text="FROM (MAIN WALLET ONLY)" styleClass="lbl-field"/>
            <ComboBox fx:id="transferAccountCombo" promptText="Choose your wallet" maxWidth="Infinity" style="-fx-font-size:13px;"/>
        </VBox>
        <VBox spacing="6">
            <Label text="RECEIVER PHONE NUMBER" styleClass="lbl-field"/>
            <TextField fx:id="receiverPhone" promptText="e.g. 0788000000" styleClass="input-field"/>
            <Label fx:id="receiverNameLabel" text="" style="-fx-text-fill:#005B2A;-fx-font-size:12px;-fx-font-weight:bold;"/>
        </VBox>
        <VBox spacing="6">
            <Label text="AMOUNT (RWF)" styleClass="lbl-field"/>
            <TextField fx:id="transferAmount" promptText="e.g. 10,000" styleClass="input-field"/>
        </VBox>
        <VBox spacing="6">
            <Label text="PIN" styleClass="lbl-field"/>
            <PasswordField fx:id="transferPin" promptText="Enter your PIN" styleClass="input-field"/>
        </VBox>

        <VBox fx:id="refIdBox" spacing="4" visible="false" managed="false"
              style="-fx-background-color:#F0F8F0;-fx-background-radius:8;-fx-padding:10 14;">
            <Label text="TRANSACTION REFERENCE" style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#6B7280;"/>
            <Label fx:id="refIdLabel" text="" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#005B2A;"/>
            <Label text="Keep this reference ID. Use it if you need to check this transaction." style="-fx-font-size:10px;-fx-text-fill:#9CA3AF;" wrapText="true"/>
        </VBox>

        <Label fx:id="transferMsg" wrapText="true"/>
        <Button text="Send Money" styleClass="btn-green" onAction="#handleTransfer" maxWidth="Infinity"/>
    </VBox>
</VBox>
