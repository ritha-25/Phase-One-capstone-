<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.atm.igiresystem.lab3.ui.controllers.SavingsController"
      stylesheets="@styles.css"
      spacing="20">

    <HBox style="-fx-background-color:#FEF3C7;-fx-background-radius:10;-fx-padding:14 18;" spacing="10" alignment="CENTER_LEFT">
        <Label text="🏦" style="-fx-font-size:16px;"/>
        <VBox spacing="2">
            <Label text="How Savings Works" style="-fx-font-weight:bold;-fx-text-fill:#92400E;-fx-font-size:13px;"/>
            <Label text="Send money from your Main Wallet to Savings. Withdraw back to wallet anytime. No fees for internal transfers."
                   style="-fx-text-fill:#92400E;-fx-font-size:11px;" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox styleClass="balance-card" spacing="6" maxWidth="480">
        <Label text="SAVINGS BALANCE" styleClass="balance-card-label"/>
        <Label fx:id="balanceLabel" text="0.00 RWF" styleClass="balance-card-amount"/>
        <Label fx:id="accountInfoLabel" text="Savings Account" styleClass="balance-card-name"/>
    </VBox>

    <VBox styleClass="card" spacing="16" maxWidth="480">
        <Label text="Move Money" styleClass="lbl-screen-title"/>
        <Separator/>

        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="SAVINGS ACCOUNT" styleClass="lbl-field"/>
                <ComboBox fx:id="accountCombo" maxWidth="Infinity" style="-fx-font-size:13px;" onAction="#onAccountSelected"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="MAIN WALLET" styleClass="lbl-field"/>
                <ComboBox fx:id="walletCombo" maxWidth="Infinity" style="-fx-font-size:13px;"/>
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="AMOUNT (RWF)" styleClass="lbl-field"/>
            <TextField fx:id="amountField" promptText="e.g. 50,000" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="PIN" styleClass="lbl-field"/>
            <PasswordField fx:id="pinField" promptText="Enter your PIN" styleClass="input-field"/>
        </VBox>

        <Label fx:id="messageLabel" wrapText="true"/>

        <HBox spacing="12">
            <Button text="💳 → 🏦  Save Money" styleClass="btn-green" onAction="#handleSaveFromWallet"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="🏦 → 💳  Withdraw to Wallet" styleClass="btn-orange" onAction="#handleWithdrawToWallet"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </VBox>
</VBox>
